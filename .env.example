NODE_ENV=development
PORT=3001
DATA_DIR=./data
UPLOAD_DIR=./uploads

NEXUSOS_API_BASE_URL=http://localhost:18080/api/v1
NEXUSOS_API_KEY=mock-api-key
NEXUSOS_TENANT_ID=8133c675-3bb4-4ace-ba10-1e83299cf761
NEXUSOS_APP_KEY=platform-api-tester

# 生产必填；平台服务端调用启动接口时使用，至少 32 位随机值。
APP_PUBLIC_URL=https://weekly.example.com
PLATFORM_LAUNCH_SECRET=replace-with-at-least-32-random-characters
LAUNCH_TICKET_TTL_SECONDS=120
SESSION_TTL_HOURS=8
SESSION_COOKIE_NAME=weekly_session

# 仅本机开发测试使用；生产环境即使设置也不会启用。
ENABLE_LOCAL_TEST_ENTRY=false

# 可选：平台通过可信反向代理承载应用时使用。
TRUSTED_IDENTITY_HEADER=x-authenticated-user-id
TRUSTED_PROXY_SECRET_HEADER=x-trusted-proxy-secret
TRUSTED_PROXY_SECRET=replace-with-at-least-32-random-characters
CORS_ALLOWED_ORIGINS=https://weekly.example.com
FRAME_ANCESTORS='self' https://platform.example.com

# 生产环境必须连接 clamd。
CLAMAV_HOST=clamav.internal
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=15000

PLATFORM_TIMEOUT_MS=20000
RATE_LIMIT_PER_MINUTE=180
AGENT_RATE_LIMIT_PER_MINUTE=6
